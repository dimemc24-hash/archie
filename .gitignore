.env
*.env
auth.json
*.key
*.pem
id_rsa*
*secret*
*token*

# --- runtime / generated ---
artifacts/
locks/
__pycache__/
*.pyc
*.log
*.err
.stage4_seen

# --- manual backups (git replaces these) ---
*.bak*

# --- swarm local tuning (untracked, box-side only) ---
.swarm-local.json
